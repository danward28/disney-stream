# Disney Piano Stream Configuration
# Copy to .env and fill in your values

# Required for Piano generator (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Required for YouTube streaming
YOUTUBE_STREAM_KEY=xxxx-xxxx-xxxx-xxxx

# Optional: Suno API (for Suno generator)
SUNO_API_KEY=

# Web UI port (default: 8080)
FLASK_PORT=8080

# Flask secret key (change to random string)
FLASK_SECRET_KEY=change-me-to-a-random-string
